# techslop — credentials & config
#
# Copy this file to one of:
#   .env                 (default)
#   .env.<channel>       (e.g. .env.swiftbible) — selected via TECHSLOP_ENV=<channel>
#
# Then run:
#   uv run python pipeline.py run                       # uses .env
#   TECHSLOP_ENV=swiftbible uv run python pipeline.py run   # uses .env.swiftbible
#
# Comments next to each var explain where to get the credential.

# ─────────────────────────────────────────────────────────────────────────
# Script generation
# ─────────────────────────────────────────────────────────────────────────

# OpenAI — used for both gpt-4o-mini script generation AND gpt-image-2 grids.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...


# ─────────────────────────────────────────────────────────────────────────
# Voice synthesis
# ─────────────────────────────────────────────────────────────────────────

# Provider: "edge" (free Microsoft Edge), "openai", "elevenlabs", or
# "chatterbox" (local, runs on Apple Silicon MPS, supports voice cloning).
# Recommended: chatterbox.
TTS_PROVIDER=chatterbox

# Chatterbox: path to a 30–60s clean wav of the target voice.
# Leave empty to use Chatterbox's default voice.
# Example: CHATTERBOX_VOICE_REF=/Users/you/voices/me.wav
CHATTERBOX_VOICE_REF=

# ElevenLabs (optional fallback). Get an API key + cloned voice_id at:
#   https://elevenlabs.io/app/voice-lab
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=


# ─────────────────────────────────────────────────────────────────────────
# Image generation (gpt-image-2 grid for character-consistent keyframes)
# ─────────────────────────────────────────────────────────────────────────

# gpt-image-2 size. 2048x2048 gives 1024x1024 panels in a 2x2 grid.
IMAGE_SIZE=2048x2048

# One-line description of the recurring character/host that should appear
# in every panel of every video for this channel.
# Example for techslop: "30s tech-bro narrator, denim jacket, glasses, neon-lit room"
# Example for a devotional channel: "warm-lit silhouette of a person reading at sunrise"
CHARACTER_BRIEF=


# ─────────────────────────────────────────────────────────────────────────
# Motion video (Kling 2.1 Pro i2v via fal.ai)
# ─────────────────────────────────────────────────────────────────────────

# fal.ai API key — https://fal.ai/dashboard/keys
# Used for Kling 2.1 Pro image-to-video. ~$1.40 per 5s clip.
FAL_KEY=

# Clip duration: "5" or "10" seconds. 5s is the cheap default.
MOTION_DURATION=5


# ─────────────────────────────────────────────────────────────────────────
# YouTube (works today)
# ─────────────────────────────────────────────────────────────────────────

# YouTube Data API v3 OAuth credentials.
# 1) Create OAuth client at: https://console.cloud.google.com/apis/credentials
#    Application type: Desktop app
# 2) Enable YouTube Data API v3 for the project.
# 3) Generate a refresh token. Easiest: use rclone or oauth2client locally,
#    granting the youtube.upload scope.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=


# ─────────────────────────────────────────────────────────────────────────
# TikTok Content Posting API
# ─────────────────────────────────────────────────────────────────────────

# 1) Register a TikTok Developer app: https://developers.tiktok.com/apps
# 2) Add the "Content Posting API" product (requires review, ~3–7 days).
# 3) Run the OAuth login flow with scope `video.upload` against your channel
#    account; capture the refresh_token.
# Until production approval, uploads land in the user's mobile drafts inbox.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=


# ─────────────────────────────────────────────────────────────────────────
# Instagram Reels (Graph API)
# ─────────────────────────────────────────────────────────────────────────

# 1) Convert your IG account to Business or Creator and connect to a Facebook Page.
# 2) Register a Meta app: https://developers.facebook.com/apps/
# 3) Add the "Instagram Graph API" product, request `instagram_content_publish`
#    + `pages_read_engagement` + `pages_show_list` (~5–10 day review).
# 4) Generate a long-lived Page access token via Graph API Explorer.
# 5) Get the IG Business Account ID via:
#       GET /v21.0/{page_id}?fields=instagram_business_account&access_token=...
#
# Note: Reels publishing requires the video to be at a public HTTPS URL.
# Set INSTAGRAM_PUBLIC_VIDEO_URL_TEMPLATE to a URL that includes {filename}.
# Easiest: Cloudflare R2 / AWS S3 with public-read on a per-file basis.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_PAGE_ID=
INSTAGRAM_PUBLIC_VIDEO_URL_TEMPLATE=https://your-bucket.example.com/techslop/{filename}


# ─────────────────────────────────────────────────────────────────────────
# LinkedIn (UGC Posts API)
# ─────────────────────────────────────────────────────────────────────────

# 1) Register a LinkedIn app: https://www.linkedin.com/developers/apps
# 2) Request access to "Share on LinkedIn" + "Sign In with LinkedIn".
#    For posting as an organization, also request "Marketing Developer Platform".
# 3) Run 3-legged OAuth with scope `w_member_social` (or `w_organization_social`),
#    capture the access_token.
# 4) Owner URN format:
#      Person: urn:li:person:<your-id>   (find via /v2/me)
#      Org:    urn:li:organization:<id>
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_OWNER_URN=


# ─────────────────────────────────────────────────────────────────────────
# X / Twitter
# ─────────────────────────────────────────────────────────────────────────
# X API v2 media uploads require the Basic tier ($200/mo) as of 2026.
# Manual upload is recommended until a channel earns its first dollar.


# ─────────────────────────────────────────────────────────────────────────
# Storage
# ─────────────────────────────────────────────────────────────────────────

DATABASE_PATH=techslop.db
OUTPUT_DIR=output


# ─────────────────────────────────────────────────────────────────────────
# Source filters (techslop ingest — ignore for non-tech channels)
# ─────────────────────────────────────────────────────────────────────────

REDDIT_SUBREDDITS=technology,programming,machinelearning,artificial,LocalLLaMA
FOURCHAN_KEYWORDS=AI,LLM,GPU,linux,rust,python,open source,self-hosted,homelab,programming
X_KEYWORDS=AI breakthrough,new programming language,open source release,tech layoffs,GPU,LLM
